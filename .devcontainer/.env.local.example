# Copy to `.env.local` (git-ignored) and fill in.
#
# These 5 secrets mirror ci/.env.local. They are injected into the container
# environment (docker-compose env_file) and materialized into the repo's .env
# files by ci/fill-envs.sh on every container start. Empty values are allowed —
# the app boots without them, but e.g. map tiles won't render.
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
MAPBOX_ACCESS_TOKEN=
THUNDERFOREST_API_KEY=
STRIPE_PUBLISHABLE_KEY=

# ── Repo bootstrap (optional; used by bootstrap-repo.sh) ──────────────────────
# The repo cloned into the dev container's named volume. Override to clone a fork.
REPO_URL=https://github.com/WelcometoMyGarden/welcometomygarden.git
# GitHub Personal Access Token for private/rate-limited cloning. Injected into
# the clone URL and never written to the stored git remote.
GITHUB_PAT=
# Branch to check out (default: the remote's default branch).
REPO_BRANCH=
