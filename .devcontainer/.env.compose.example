# Env vars for compose file interpolation
# Use a locally-built base image (see ci/local-build.sh) instead of the published one.
BASE_IMAGE=wtmg-e2e-ci:24
# Name of the created container.
CONTAINER_NAME=

# ── Server ports ──────────────────────────────────────────────────────────────
# Filled here to the standard ports + 10000, so this container runs alongside a
# host dev environment that uses the default ports. Ports are forwarded 1:1 and
# the same values drive firebase.json, `vite --port` and the browser-facing
# VITE_EMULATOR_*_PORT (see start-dev.sh). Clear a line to fall back to its
# standard port (the docker-compose.yml default).
WTMG_PORT_FRONTEND=15173   # standard 5173  — Vite dev server
WTMG_PORT_HOSTING=14000    # standard 4000  — Firebase Hosting emulator
WTMG_PORT_EMU_UI=14001     # standard 4001  — Firebase Emulator UI
WTMG_PORT_FUNCTIONS=15001  # standard 5001  — Cloud Functions emulator
WTMG_PORT_FIRESTORE=18080  # standard 8080  — Firestore emulator
WTMG_PORT_AUTH=19099       # standard 9099  — Auth emulator
WTMG_PORT_STORAGE=19199    # standard 9199  — Storage emulator
