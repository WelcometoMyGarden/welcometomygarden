{
  "name": "welcome-to-my-garden",
  "license": "AGPL-3.0-only",
  "description": "Welcome To My Garden is a network of citizens offering camping spots in their gardens to slow travellers.",
  "homepage": "https://welcometomygarden.org",
  "bugs": {
    "url": "https://github.com/WelcometoMyGarden/welcometomygarden/issues"
  },
  "funding": "https://welcometomygarden.org/about-membership",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "dev": "vite --host",
    "dev:staging": "vite --mode staging --host",
    "dev:push": "vite --mode devpush --host",
    "dev:prod": "vite --mode production --host",
    "build": "vite build",
    "build:demo": "vite build --mode development",
    "build:prod": "vite build --mode production",
    "build:staging": "vite build --mode staging",
    "preview": "vite preview",
    "test:e2e": "playwright test --project Mobile",
    "test:unit": "vitest",
    "check": "svelte-kit sync && svelte-check --compiler-warnings 'security-anchor-rel-noreferrer:ignore' --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --compiler-warnings 'security-anchor-rel-noreferrer:ignore' --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --plugin-search-dir . --check . && eslint .",
    "format": "prettier --plugin-search-dir . --write .",
    "firebase:demo": "firebase --project demo-test emulators:start 2>&1 | grep -v 'i  hosting: 127.0.0.1 - -'",
    "firebase:demo-seed": "firebase --project demo-test emulators:exec --ui api/seeders/simple.js 2>&1 | grep -v 'i  hosting: 127.0.0.1 - -'",
    "firebase:debug": "firebase --project demo-test emulators:start --inspect-functions",
    "firebase:staging": "firebase --project staging emulators:start --only functions,tasks",
    "firebase:staging-all": "firebase --project staging emulators:start",
    "firebase:staging-push": "STAGING=true firebase --project staging emulators:exec --ui api/seeders/simple.js",
    "stripe:staging": "stripe listen --events customer.subscription.deleted,customer.subscription.updated,invoice.finalized,invoice.created,invoice.paid,payment_intent.processing --forward-to http://127.0.0.1:5001/wtmg-dev/europe-west1/handleStripeWebhookV2"
  },
  "devDependencies": {
    "@capacitor-community/safe-area": "^8.0.1",
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/device": "^8.0.1",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/inappbrowser": "^2.5.4",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/push-notifications": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@capawesome/capacitor-badge": "^8.0.1",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@notnotsamuel/capacitor-swipe-back": "^3.0.2",
    "@playwright/test": "^1.58.2",
    "@sentry/sveltekit": "^10.44.0",
    "@stripe/stripe-js": "^8.10.0",
    "@supabase/supabase-js": "^2.99.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^6",
    "@tmcw/togeojson": "^7.1.2",
    "@turf/turf": "^7.3.4",
    "@types/geojson": "^7946.0.16",
    "@types/lodash-es": "^4.17.12",
    "@types/md5": "^2.3.6",
    "@types/nprogress": "^0.2.3",
    "@types/smoothscroll-polyfill": "^0.3.4",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@zerodevx/svelte-img": "^2.1.2",
    "@zootools/email-spell-checker": "^1.12.0",
    "capacitor-native-settings": "^8.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-svelte": "^2.46.1",
    "file-selector": "^2.1.2",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "i18n-iso-countries": "^7.14.0",
    "iso-639-1": "^3.1.5",
    "jsonc-parser": "^3.3.1",
    "lodash-es": "^4.17.23",
    "mapbox-gl": "^3.20.0",
    "md5": "^2.3.0",
    "nprogress": "^0.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "smoothscroll-polyfill": "^0.4.4",
    "stripe": "^17.7.0",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.5",
    "svelte-i18n": "^4.0.1",
    "svelte-preprocess": "^6.0.3",
    "svelte-simple-modal": "^2.0.0",
    "svelte-stripe": "^2.0.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "ua-parser-js": "^2.0.9",
    "vite": "^7.3.1",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-mkcert": "^1.17.10",
    "vitest": "^4.1.0"
  },
  "dependenciesMeta": {
    "esbuild": {
      "built": true
    },
    "sharp": {
      "built": true
    }
  },
  "resolutions": {
    "sharp@npm:0.32.6": "0.33.5"
  },
  "type": "module",
  "packageManager": "yarn@4.12.0"
}
